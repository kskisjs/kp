<Page x:Class="BelarusQuiz.Client.Views.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0D1F0F">
  <Grid Margin="32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Верхняя панель: прогресс + таймер + счёт -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="160"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="160"/>
      </Grid.ColumnDefinitions>

      <!-- Счёт мой -->
      <Border Grid.Column="0" Style="{StaticResource Card}" Padding="12">
        <StackPanel HorizontalAlignment="Center">
          <TextBlock x:Name="TbMyName" Text="Вы" FontSize="12"
                     Foreground="#7AAB7C" HorizontalAlignment="Center"/>
          <TextBlock x:Name="TbMyScore" Text="0" FontSize="32" FontWeight="Black"
                     Foreground="#2ECC40" HorizontalAlignment="Center"/>
          <TextBlock x:Name="TbMyStreak" Text="" FontSize="11"
                     Foreground="#FFD700" HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Центр: раунд + таймер -->
      <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock x:Name="TbRound" Text="Раунд 1 из 10" FontSize="13"
                   Foreground="#7AAB7C" HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock x:Name="TbCategory" Text="" FontSize="11"
                   Foreground="#4A6B4C" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <!-- Таймер -->
        <Border Background="#162B18" CornerRadius="24" Width="56" Height="56"
                HorizontalAlignment="Center" BorderBrush="#2A4A2C" BorderThickness="2">
          <TextBlock x:Name="TbTimer" Text="15" FontSize="26" FontWeight="Black"
                     Foreground="#2ECC40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <ProgressBar x:Name="TimerBar" Style="{StaticResource TimerBar}"
                     Maximum="100" Value="100" Margin="0,8,0,0" Width="200"/>
      </StackPanel>

      <!-- Счёт соперника -->
      <Border Grid.Column="2" Style="{StaticResource Card}" Padding="12">
        <StackPanel HorizontalAlignment="Center">
          <TextBlock x:Name="TbOppName" Text="Соперник" FontSize="12"
                     Foreground="#7AAB7C" HorizontalAlignment="Center"/>
          <TextBlock x:Name="TbOppScore" Text="0" FontSize="32" FontWeight="Black"
                     Foreground="#E74C3C" HorizontalAlignment="Center"/>
          <TextBlock x:Name="TbOppStreak" Text="" FontSize="11"
                     Foreground="#FFD700" HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Разделитель -->
    <Separator Grid.Row="1" Background="#2A4A2C" Margin="0,0,0,20"/>

    <!-- Вопрос -->
    <Border Grid.Row="2" Style="{StaticResource Card}">
      <StackPanel VerticalAlignment="Center">
        <TextBlock x:Name="TbQuestion"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="#FFFFFF"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"
                   MaxWidth="700"/>
      </StackPanel>
    </Border>

    <!-- Варианты ответов (2x2) -->
    <Grid Grid.Row="3" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="16"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Button x:Name="Btn0" Grid.Column="0" Grid.Row="0"
              Style="{StaticResource BtnAnswer}" Click="Answer_Click" Tag="0"/>
      <Button x:Name="Btn1" Grid.Column="2" Grid.Row="0"
              Style="{StaticResource BtnAnswer}" Click="Answer_Click" Tag="1"/>
      <Button x:Name="Btn2" Grid.Column="0" Grid.Row="2"
              Style="{StaticResource BtnAnswer}" Click="Answer_Click" Tag="2"/>
      <Button x:Name="Btn3" Grid.Column="2" Grid.Row="2"
              Style="{StaticResource BtnAnswer}" Click="Answer_Click" Tag="3"/>
    </Grid>

    <!-- Результат раунда -->
    <Border x:Name="RoundResultPanel" Grid.Row="4"
            Background="#162B18" CornerRadius="10"
            Padding="16,12" Margin="0,16,0,0"
            Visibility="Collapsed">
      <StackPanel>
        <TextBlock x:Name="TbResult" FontSize="16" FontWeight="Bold"
                   Foreground="#2ECC40" HorizontalAlignment="Center"/>
        <TextBlock x:Name="TbExplanation" FontSize="12"
                   Foreground="#7AAB7C" HorizontalAlignment="Center"
                   TextWrapping="Wrap" Margin="0,6,0,0"/>
      </StackPanel>
    </Border>
  </Grid>
</Page>
