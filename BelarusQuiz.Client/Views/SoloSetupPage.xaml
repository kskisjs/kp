<Page x:Class="BelarusQuiz.Client.Views.SoloSetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Настройка игры">

    <Page.Resources>
        <Style x:Key="BtnGreen" TargetType="Button">
            <Setter Property="Background" Value="#1A6E30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="12" Background="{TemplateBinding Background}">
                            <Border.Effect>
                                <DropShadowEffect Color="#2ECC40" ShadowDepth="0" BlurRadius="14" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22913E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnBack" TargetType="Button">
            <Setter Property="Background" Value="#0E2212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A4A2C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#162A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnCat" TargetType="Button">
            <Setter Property="Background" Value="#0E2212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1E3A22"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Height" Value="76"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#162A1A"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2A5A2C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnCatActive" TargetType="Button" BasedOn="{StaticResource BtnCat}">
            <Setter Property="Background" Value="#1A4E28"/>
            <Setter Property="BorderBrush" Value="#2ECC40"/>
        </Style>
        <Style x:Key="BtnNum" TargetType="Button">
            <Setter Property="Background" Value="#0E2212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1E3A22"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#162A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnNumActive" TargetType="Button" BasedOn="{StaticResource BtnNum}">
            <Setter Property="Background" Value="#1A4E28"/>
            <Setter Property="BorderBrush" Value="#2ECC40"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#071209" Offset="0"/>
                    <GradientStop Color="#0B1C0E" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ ЛЕВАЯ: Категории ══ -->
            <Grid Grid.Column="0">
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#071209" Offset="0"/>
                            <GradientStop Color="#0C1E0F" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Кнопка назад -->
                    <Button Grid.Row="0" Content="← Назад" Style="{StaticResource BtnBack}"
                            HorizontalAlignment="Left" Margin="20,20,0,0"
                            Click="BtnBack_Click"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="40,0">

                        <TextBlock Text="Выбери категорию вопросов"
                                   FontSize="20" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Нажми на нужную категорию"
                                   FontSize="12" Foreground="#3A6040"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <!-- Все категории -->
                        <Button x:Name="BtnCatAll" Style="{StaticResource BtnCatActive}"
                                Click="BtnCat_Click" Tag="All" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Все категории (случайные)" FontSize="14"
                                           FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Вопросы из всех тем вперемешку"
                                           FontSize="11" Foreground="#4A8A50"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Сетка категорий 2x3 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Button x:Name="BtnCatGeo" Grid.Column="0" Grid.Row="0"
                                    Style="{StaticResource BtnCat}" Click="BtnCat_Click" Tag="Geography">
                                <StackPanel>
                                    <TextBlock Text="🗺️" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="География" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnCatHist" Grid.Column="2" Grid.Row="0"
                                    Style="{StaticResource BtnCat}" Click="BtnCat_Click" Tag="History">
                                <StackPanel>
                                    <TextBlock Text="📜" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="История" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnCatCult" Grid.Column="0" Grid.Row="2"
                                    Style="{StaticResource BtnCat}" Click="BtnCat_Click" Tag="Culture">
                                <StackPanel>
                                    <TextBlock Text="🎭" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Культура" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnCatNat" Grid.Column="2" Grid.Row="2"
                                    Style="{StaticResource BtnCat}" Click="BtnCat_Click" Tag="Nature">
                                <StackPanel>
                                    <TextBlock Text="🌿" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Природа" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnCatSym" Grid.Column="0" Grid.Row="4"
                                    Style="{StaticResource BtnCat}" Click="BtnCat_Click" Tag="Symbols">
                                <StackPanel>
                                    <TextBlock Text="🏛️" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Символика" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnCatPpl" Grid.Column="2" Grid.Row="4"
                                    Style="{StaticResource BtnCat}" Click="BtnCat_Click" Tag="People">
                                <StackPanel>
                                    <TextBlock Text="🧑" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Знаменитости" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>

            <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right" Fill="#1A3A1E"/>

            <!-- ══ ПРАВАЯ: Количество вопросов + старт ══ -->
            <Grid Grid.Column="1">
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#081009" Offset="0"/>
                            <GradientStop Color="#0A1A0C" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <StackPanel VerticalAlignment="Center" Margin="40,0">

                    <TextBlock Text="Количество вопросов" FontSize="20" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnQ5"  Grid.Column="0" Content="5"  Tag="5"
                                Style="{StaticResource BtnNumActive}" Click="BtnCount_Click"/>
                        <Button x:Name="BtnQ10" Grid.Column="2" Content="10" Tag="10"
                                Style="{StaticResource BtnNum}" Click="BtnCount_Click"/>
                        <Button x:Name="BtnQ15" Grid.Column="4" Content="15" Tag="15"
                                Style="{StaticResource BtnNum}" Click="BtnCount_Click"/>
                        <Button x:Name="BtnQ20" Grid.Column="6" Content="20" Tag="20"
                                Style="{StaticResource BtnNum}" Click="BtnCount_Click"/>
                    </Grid>

                    <!-- Система очков -->
                    <Border Background="#0E2212" CornerRadius="12" Padding="16,14"
                            BorderBrush="#1E3A22" BorderThickness="1" Margin="0,0,0,28">
                        <StackPanel>
                            <TextBlock Text="Система очков" FontSize="14" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Правильный ответ" Foreground="#4A7A50" FontSize="13"/>
                                <TextBlock Grid.Column="1" Text="+100 очков"
                                           Foreground="#2ECC40" FontSize="13" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Серия правильных (x10 за каждый)" Foreground="#4A7A50" FontSize="13"/>
                                <TextBlock Grid.Column="1" Text="до +50"
                                           Foreground="#E67E22" FontSize="13" FontWeight="Bold"/>
                            </Grid>
                            <Border Height="1" Background="#1E3A22" Margin="0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Максимум за вопрос" Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="150 очков"
                                           Foreground="White" FontSize="13" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Итог выбора -->
                    <Border Background="#0E2212" CornerRadius="10" Padding="14,10"
                            BorderBrush="#1E3A22" BorderThickness="1" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TbSelectedCat" Text="Все категории"
                                       Foreground="White" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Text="  •  " Foreground="#3A6040" FontSize="13"/>
                            <TextBlock x:Name="TbSelectedCount" Text="5 вопросов"
                                       Foreground="White" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Старт -->
                    <Button Content="Начать игру" Style="{StaticResource BtnGreen}"
                            Click="BtnStart_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>