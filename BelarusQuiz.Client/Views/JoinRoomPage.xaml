<Page x:Class="BelarusQuiz.Client.Views.JoinRoomPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0D1F0F">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="380"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="1" VerticalAlignment="Center">
      <Button Content="← Назад" Style="{StaticResource BtnDark}"
              Height="36" Width="100" HorizontalAlignment="Left"
              Click="BtnBack_Click" Margin="0,0,0,32"/>

      <TextBlock Text="ПОДКЛЮЧЕНИЕ К КОМНАТЕ" FontSize="22" FontWeight="Black"
                 Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,32"/>

      <TextBlock Text="КОД КОМНАТЫ" FontSize="11" FontWeight="Bold"
                 Foreground="#7AAB7C" Margin="0,0,0,6"/>
      <TextBox x:Name="TbCode" Style="{StaticResource InputBox}"
               FontSize="24" FontWeight="Bold" MaxLength="6"
               CharacterCasing="Upper" TextAlignment="Center"/>

      <Button Content="ПОДКЛЮЧИТЬСЯ" Style="{StaticResource BtnGreen}"
              Click="BtnConnect_Click" Margin="0,24,0,0"/>

      <TextBlock x:Name="TbStatus" Text="" FontSize="13"
                 Foreground="#7AAB7C" HorizontalAlignment="Center"
                 Margin="0,16,0,0" TextWrapping="Wrap"/>
    </StackPanel>
  </Grid>
</Page>
