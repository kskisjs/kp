<!-- Путь: BelarusQuiz.Client/Views/SettingsPage.xaml  (НОВЫЙ ФАЙЛ) -->
<Page x:Class="BelarusQuiz.Client.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Настройки" Background="#0A180C">

    <Page.Resources>
        <Style x:Key="BtnGreen" TargetType="Button">
            <Setter Property="Background" Value="#1A6E30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2ECC40"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#238A3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnRed" TargetType="Button">
            <Setter Property="Background" Value="#7A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#E74C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#922222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnBack" TargetType="Button">
            <Setter Property="Background" Value="#162A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A4A2C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#162A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A4A2C"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2ECC40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0.5,1">
                    <GradientStop Color="#0A180C" Offset="0"/>
                    <GradientStop Color="#0E2412" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Border MaxWidth="480" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="#122018" BorderBrush="#2A4A2C" BorderThickness="1"
                CornerRadius="20" Padding="36,28">
            <StackPanel>

                <!-- Заголовок -->
                <Grid Margin="0,0,0,24">
                    <Button Content="←" Style="{StaticResource BtnBack}"
                            HorizontalAlignment="Left" Click="BtnBack_Click"/>
                    <TextBlock Text="⚙ Настройки" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Профиль -->
                <Border Background="#162A1A" CornerRadius="12" Padding="16,14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="👤 ПРОФИЛЬ" FontSize="11" FontWeight="Bold"
                                   Foreground="#557A5A" Margin="0,0,0,12"/>

                        <!-- Аватар + никнейм -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="50" Height="50" CornerRadius="25"
                                    Background="#1A6E30">
                                <TextBlock x:Name="TbInitials" Text="??" Foreground="White"
                                           FontSize="18" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="TbNickname" Text="" Foreground="White"
                                           FontSize="16" FontWeight="Bold"/>
                                <TextBlock x:Name="TbStats" Text="" Foreground="#7CB87E"
                                           FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Статистика -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#1E3820" CornerRadius="8" Padding="10,8" Margin="0,0,4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="TbWins" Text="0" FontSize="20" FontWeight="Black"
                                               Foreground="#2ECC40" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Побед" FontSize="10" Foreground="#557A5A"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#1E3820" CornerRadius="8" Padding="10,8" Margin="4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="TbGames" Text="0" FontSize="20" FontWeight="Black"
                                               Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Игр" FontSize="10" Foreground="#557A5A"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#1E3820" CornerRadius="8" Padding="10,8" Margin="4,0,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="TbScore" Text="0" FontSize="20" FontWeight="Black"
                                               Foreground="#F1C40F" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Очков" FontSize="10" Foreground="#557A5A"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Соединение -->
                <Border Background="#162A1A" CornerRadius="12" Padding="16,14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🌐 СОЕДИНЕНИЕ" FontSize="11" FontWeight="Bold"
                                   Foreground="#557A5A" Margin="0,0,0,10"/>
                        <TextBlock Text="Адрес сервера" FontSize="12" Foreground="#7CB87E"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="TbServer" Style="{StaticResource InputField}"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки -->
                <Button Content="💾 СОХРАНИТЬ" Style="{StaticResource BtnGreen}"
                        Click="BtnSave_Click" Margin="0,0,0,10"/>
                <Button Content="🚪 ВЫЙТИ ИЗ АККАУНТА" Style="{StaticResource BtnRed}"
                        Click="BtnLogout_Click"/>

                <TextBlock x:Name="TbStatus" Text="" Foreground="#2ECC40"
                           HorizontalAlignment="Center" FontSize="13" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>