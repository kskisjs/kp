<Page x:Class="BelarusQuiz.Client.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Настройки">

    <Page.Resources>
        <Style x:Key="BtnGreen" TargetType="Button">
            <Setter Property="Background" Value="#1A6E30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10" Background="{TemplateBinding Background}">
                            <Border.Effect>
                                <DropShadowEffect Color="#2ECC40" ShadowDepth="0" BlurRadius="12" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22913E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnRed" TargetType="Button">
            <Setter Property="Background" Value="#7A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10" Background="{TemplateBinding Background}"
                                BorderBrush="#E74C3C" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#922222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnBack" TargetType="Button">
            <Setter Property="Background" Value="#0E2212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A4A2C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#0E2212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A4A2C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="CaretBrush" Value="#2ECC40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2ECC40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#071209" Offset="0"/>
                    <GradientStop Color="#0B1C0E" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ ЛЕВАЯ: Профиль ══ -->
            <Grid Grid.Column="0">
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#071209" Offset="0"/>
                            <GradientStop Color="#0C1E0F" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="40" MaxWidth="360">

                    <!-- Назад + заголовок -->
                    <Grid Margin="0,0,0,32">
                        <Button Content="←" Style="{StaticResource BtnBack}"
                                HorizontalAlignment="Left" Click="BtnBack_Click"/>
                        <TextBlock Text="⚙  Настройки" FontSize="22" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Большой аватар -->
                    <Grid Width="110" Height="110" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Ellipse Fill="#1A6E30">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2ECC40" ShadowDepth="0" BlurRadius="24" Opacity="0.5"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Margin="7" Stroke="#2ECC40" StrokeThickness="2" Fill="Transparent"/>
                        <TextBlock x:Name="TbInitials" Text="??" FontSize="38"
                                   FontWeight="Black" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Имя -->
                    <TextBlock x:Name="TbNickname" Text="Игрок" FontSize="24"
                               FontWeight="Black" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TbLoginText" Text="" FontSize="12"
                               Foreground="#3A6040" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <Border Background="#1A6E30" CornerRadius="8" Padding="14,6"
                            HorizontalAlignment="Center" Margin="0,0,0,28">
                        <Border.Effect>
                            <DropShadowEffect Color="#2ECC40" ShadowDepth="0" BlurRadius="10" Opacity="0.4"/>
                        </Border.Effect>
                        <TextBlock x:Name="TbLevel" Text="Уровень 1" FontSize="14"
                                   FontWeight="Bold" Foreground="White"/>
                    </Border>

                    <!-- Статистика 3 плитки -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#0E2212" CornerRadius="12"
                                Padding="8,16" BorderBrush="#1E3A22" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🏆" FontSize="22" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TbWins" Text="0" FontSize="22"
                                           FontWeight="Black" Foreground="#2ECC40"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Побед" FontSize="10" Foreground="#3A6040"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#0E2212" CornerRadius="12"
                                Padding="8,16" BorderBrush="#1E3A22" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🎮" FontSize="22" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TbGames" Text="0" FontSize="22"
                                           FontWeight="Black" Foreground="White"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Игр" FontSize="10" Foreground="#3A6040"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Background="#0E2212" CornerRadius="12"
                                Padding="8,16" BorderBrush="#1E3A22" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⭐" FontSize="22" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TbScore" Text="0" FontSize="22"
                                           FontWeight="Black" Foreground="#F1C40F"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Очков" FontSize="10" Foreground="#3A6040"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right" Fill="#1A3A1E"/>

            <!-- ══ ПРАВАЯ: Настройки ══ -->
            <Grid Grid.Column="1">
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#081009" Offset="0"/>
                            <GradientStop Color="#0A1A0C" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="48,40">

                        <TextBlock Text="Подключение" FontSize="20" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,20"/>

                        <TextBlock Text="АДРЕС СЕРВЕРА" FontSize="11" FontWeight="Bold"
                                   Foreground="#4A8A50" Margin="0,0,0,8"/>
                        <TextBox x:Name="TbServer" Style="{StaticResource Input}" Margin="0,0,0,8"/>

                        <!-- Подсказка про интернет -->
                        <Border Background="#0E2212" CornerRadius="10" Padding="14,12"
                                BorderBrush="#1E3A22" BorderThickness="1" Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock Text="🌐 Игра через интернет" FontSize="13"
                                           FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#4A7A50"
                                           Margin="0,0,0,6">
                                    <Run Text="1. Скачай "/>
                                    <Run Text="ngrok.com" Foreground="#2ECC40" FontWeight="Bold"/>
                                    <Run Text=" → запусти: ngrok http 5000"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#4A7A50"
                                           Margin="0,0,0,6"
                                           Text="2. Получишь ссылку: https://abc123.ngrok.io"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#4A7A50"
                                           Text="3. Отправь эту ссылку другу — он введёт её сюда"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Аккаунт" FontSize="20" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,20"/>

                        <Button Content="💾  СОХРАНИТЬ НАСТРОЙКИ" Style="{StaticResource BtnGreen}"
                                Click="BtnSave_Click" Margin="0,0,0,10"/>

                        <TextBlock x:Name="TbStatus" Text="" Foreground="#2ECC40"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                        <Button Content="🚪  ВЫЙТИ ИЗ АККАУНТА" Style="{StaticResource BtnRed}"
                                Click="BtnLogout_Click"/>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>