<Page x:Class="BelarusQuiz.Client.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#0D1F0F">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="420"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Фоновый градиент -->
    <Rectangle Grid.ColumnSpan="3">
      <Rectangle.Fill>
        <RadialGradientBrush Center="0.5,0.3" RadiusX="0.7" RadiusY="0.6">
          <GradientStop Color="#0D2E10" Offset="0"/>
          <GradientStop Color="#0D1F0F" Offset="1"/>
        </RadialGradientBrush>
      </Rectangle.Fill>
    </Rectangle>

    <!-- Центральная колонка -->
    <StackPanel Grid.Column="1" VerticalAlignment="Center">

      <!-- Логотип / заголовок -->
      <TextBlock Text="🌿" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,8"/>
      <TextBlock Text="БЕЛАРУСЬ" FontSize="42" FontWeight="Black"
                 Foreground="#FFFFFF" HorizontalAlignment="Center"
                />
      <TextBlock Text="ЗНАЙ СВОЙ КРАЙ" FontSize="20" FontWeight="Bold"
                 Foreground="#2ECC40" HorizontalAlignment="Center"
                 Margin="0,4,0,6"/>
      <TextBlock Text="Многопользовательская викторина-баттл"
                 FontSize="13" Foreground="#7AAB7C"
                 HorizontalAlignment="Center" Margin="0,0,0,40"/>

      <!-- Поле: никнейм -->
      <TextBlock Text="ВАШ НИКНЕЙМ" FontSize="11" FontWeight="Bold"
                 Foreground="#7AAB7C" Margin="0,0,0,6"/>
      <TextBox x:Name="TbNickname" Style="{StaticResource InputBox}"
               MaxLength="20" Text="Игрок1"/>

      <!-- Поле: адрес сервера -->
      <TextBlock Text="АДРЕС СЕРВЕРА" FontSize="11" FontWeight="Bold"
                 Foreground="#7AAB7C" Margin="0,16,0,6"/>
      <TextBox x:Name="TbServer" Style="{StaticResource InputBox}"
               Text="http://localhost:5000"/>

      <Separator Background="#2A4A2C" Margin="0,28,0,28"/>

      <!-- Кнопки -->
      <Button Content="⚔  БЫСТРАЯ ИГРА (СОЗДАТЬ)"
              Style="{StaticResource BtnGreen}"
              Click="BtnCreate_Click" Margin="0,0,0,12"/>

      <Button Content="🔗  ПОДКЛЮЧИТЬСЯ К КОМНАТЕ"
              Style="{StaticResource BtnDark}"
              Click="BtnJoin_Click" Margin="0,0,0,12"/>

      <Button Content="🤖  ИГРА ПРОТИВ БОТА (СОЛО)"
              Style="{StaticResource BtnDark}"
              Click="BtnSolo_Click"/>

      <!-- Статус подключения -->
      <TextBlock x:Name="TbStatus" Text="" FontSize="12"
                 Foreground="#7AAB7C" HorizontalAlignment="Center"
                 Margin="0,20,0,0" TextWrapping="Wrap"/>

    </StackPanel>

    <!-- Версия -->
    <TextBlock Grid.Column="2" Text="v1.0" FontSize="11"
               Foreground="#2A4A2C" VerticalAlignment="Bottom"
               HorizontalAlignment="Right" Margin="0,0,16,12"/>
  </Grid>
</Page>
