<!-- Путь: BelarusQuiz.Client/Views/LoginPage.xaml  (ЗАМЕНИТЬ) -->
<Page x:Class="BelarusQuiz.Client.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход">

    <Page.Resources>
        <Style x:Key="BtnGreen" TargetType="Button">
            <Setter Property="Background" Value="#1A6E30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10" Background="{TemplateBinding Background}">
                            <Border.Effect>
                                <DropShadowEffect Color="#2ECC40" ShadowDepth="0" BlurRadius="12" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22913E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#155526"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnLink" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Нет аккаунта?" FontSize="13"
                                       Foreground="#4A7A50" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="tb" Text="Зарегистрироваться" FontSize="14"
                                       FontWeight="Bold" Foreground="#2ECC40" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tb" Property="Foreground" Value="#3AFF50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#0E2212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A4A2C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="CaretBrush" Value="#2ECC40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2ECC40"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Pass" TargetType="PasswordBox">
            <Setter Property="Background" Value="#0E2212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A4A2C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="CaretBrush" Value="#2ECC40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2ECC40"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Фон -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#071209" Offset="0"/>
                    <GradientStop Color="#0A1C0D" Offset="0.5"/>
                    <GradientStop Color="#071A0B" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Декоративные круги -->
        <Ellipse Width="600" Height="600" HorizontalAlignment="Left"
                 VerticalAlignment="Bottom" Margin="-200,0,0,-200">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0D2E12" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="500" Height="500" HorizontalAlignment="Right"
                 VerticalAlignment="Top" Margin="0,-150,-150,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0D2E12" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Двухколоночный макет -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ ЛЕВАЯ ПАНЕЛЬ ══ -->
            <Grid Grid.Column="0">
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#071209" Offset="0"/>
                            <GradientStop Color="#0C1E0F" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Орнаментальная сетка -->
                <Canvas Opacity="0.05">
                    <Rectangle Canvas.Left="0"   Canvas.Top="80"  Width="2000" Height="1" Fill="White"/>
                    <Rectangle Canvas.Left="0"   Canvas.Top="160" Width="2000" Height="1" Fill="White"/>
                    <Rectangle Canvas.Left="0"   Canvas.Top="240" Width="2000" Height="1" Fill="White"/>
                    <Rectangle Canvas.Left="0"   Canvas.Top="320" Width="2000" Height="1" Fill="White"/>
                    <Rectangle Canvas.Left="0"   Canvas.Top="400" Width="2000" Height="1" Fill="White"/>
                    <Rectangle Canvas.Left="0"   Canvas.Top="480" Width="2000" Height="1" Fill="White"/>
                    <Rectangle Canvas.Left="0"   Canvas.Top="560" Width="2000" Height="1" Fill="White"/>
                    <Rectangle Canvas.Left="80"  Canvas.Top="0" Width="1" Height="2000" Fill="White"/>
                    <Rectangle Canvas.Left="160" Canvas.Top="0" Width="1" Height="2000" Fill="White"/>
                    <Rectangle Canvas.Left="240" Canvas.Top="0" Width="1" Height="2000" Fill="White"/>
                    <Rectangle Canvas.Left="320" Canvas.Top="0" Width="1" Height="2000" Fill="White"/>
                    <Rectangle Canvas.Left="400" Canvas.Top="0" Width="1" Height="2000" Fill="White"/>
                    <Rectangle Canvas.Left="480" Canvas.Top="0" Width="1" Height="2000" Fill="White"/>
                    <Rectangle Canvas.Left="560" Canvas.Top="0" Width="1" Height="2000" Fill="White"/>
                </Canvas>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="48,0" MaxWidth="380">

                    <!-- Логотип -->
                    <Grid Width="110" Height="110" HorizontalAlignment="Center" Margin="0,0,0,28">
                        <Ellipse Fill="#132A16">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#2ECC40" ShadowDepth="0" BlurRadius="30" Opacity="0.35"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Margin="8" Stroke="#2ECC40" StrokeThickness="2" Fill="Transparent"/>
                        <TextBlock Text="❄" FontSize="54" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Заголовок -->
                    <TextBlock Text="БЕЛАРУСЬ:" FontSize="36" FontWeight="Black"
                               Foreground="White" HorizontalAlignment="Center"
                               Margin="0,0,0,4" TextAlignment="Center"/>
                    <TextBlock Text="ЗНАЙ СВОЙ КРАЙ" FontSize="32" FontWeight="Black"
                               HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,14">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2ECC40" Offset="0"/>
                                <GradientStop Color="#1A9E2C" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Многопользовательская викторина-баттл"
                               FontSize="13" Foreground="#3A5A40"
                               HorizontalAlignment="Center" Margin="0,0,0,40"/>

                    <!-- Фишки -->
                    <Border Background="#0E2212" CornerRadius="12" Padding="18,14" Margin="0,0,0,10"
                            BorderBrush="#1A3A1E" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗺️" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="60 вопросов в 6 категориях"
                                           Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="История, природа, культура и многое другое"
                                           Foreground="#3A5A40" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="#0E2212" CornerRadius="12" Padding="18,14" Margin="0,0,0,10"
                            BorderBrush="#1A3A1E" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚔️" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Баттл в реальном времени"
                                           Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Соревнуйся с друзьями онлайн"
                                           Foreground="#3A5A40" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="#0E2212" CornerRadius="12" Padding="18,14"
                            BorderBrush="#1A3A1E" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏆" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Таблица лидеров и достижения"
                                           Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Зарабатывай XP и поднимайся в рейтинге"
                                           Foreground="#3A5A40" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Разделитель -->
            <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right" Fill="#1A3A1E"/>

            <!-- ══ ПРАВАЯ ПАНЕЛЬ: ФОРМА ══ -->
            <Grid Grid.Column="1">
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#081009" Offset="0"/>
                            <GradientStop Color="#0A1A0C" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel VerticalAlignment="Center" Margin="48,40">

                        <TextBlock Text="Добро пожаловать!" FontSize="24" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock Text="Войдите в свой аккаунт" FontSize="13"
                                   Foreground="#4A7A50" Margin="0,0,0,32"/>

                        <!-- Поля -->
                        <TextBlock Text="ЛОГИН" FontSize="11" FontWeight="Bold"
                                   Foreground="#4A8A50" Margin="0,0,0,7"/>
                        <TextBox x:Name="TbLogin" Style="{StaticResource Input}" Margin="0,0,0,18"/>

                        <TextBlock Text="ПАРОЛЬ" FontSize="11" FontWeight="Bold"
                                   Foreground="#4A8A50" Margin="0,0,0,7"/>
                        <PasswordBox x:Name="PbPassword" Style="{StaticResource Pass}" Margin="0,0,0,18"/>

                        <TextBlock Text="АДРЕС СЕРВЕРА" FontSize="11" FontWeight="Bold"
                                   Foreground="#2E5535" Margin="0,0,0,7"/>
                        <TextBox x:Name="TbServer" Text="http://localhost:5000"
                                 Style="{StaticResource Input}" Margin="0,0,0,28"/>

                        <!-- Войти -->
                        <Button Content="ВОЙТИ" Style="{StaticResource BtnGreen}"
                                Click="BtnLogin_Click" Margin="0,0,0,12"/>

                        <!-- Статус -->
                        <TextBlock x:Name="TbStatus" Text="" Foreground="#E74C3C"
                                   FontSize="13" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

                        <!-- Разделитель -->
                        <Grid Margin="0,0,0,16">
                            <Border Height="1" Background="#1A3A1E" VerticalAlignment="Center"/>
                            <Border Background="#081009" Padding="10,0" HorizontalAlignment="Center">
                                <TextBlock Text="или" Foreground="#2E5535" FontSize="12"/>
                            </Border>
                        </Grid>

                        <!-- Регистрация -->
                        <Border CornerRadius="10" BorderBrush="#1A3A1E" BorderThickness="1"
                                Padding="0,14">
                            <Button Style="{StaticResource BtnLink}" Click="BtnRegister_Click"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>