<!-- Путь: BelarusQuiz.Client/Views/LeaderboardPage.xaml  (НОВЫЙ ФАЙЛ) -->
<Page x:Class="BelarusQuiz.Client.Views.LeaderboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Таблица лидеров" Background="#0A180C">

    <Page.Resources>
        <Style x:Key="BtnTab" TargetType="Button">
            <Setter Property="Background" Value="#162A1A"/>
            <Setter Property="Foreground" Value="#7CB87E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="tb" Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E3820"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnTabActive" TargetType="Button" BasedOn="{StaticResource BtnTab}">
            <Setter Property="Background" Value="#1A6E30"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BtnBack" TargetType="Button">
            <Setter Property="Background" Value="#162A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A4A2C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Фон -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0.5,1">
                    <GradientStop Color="#0A180C" Offset="0"/>
                    <GradientStop Color="#0E2412" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Основной контент -->
        <Border MaxWidth="600" HorizontalAlignment="Center"
                Background="#122018" BorderBrush="#2A4A2C" BorderThickness="1"
                CornerRadius="16" Margin="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Grid Grid.Row="0" Margin="20,20,20,16">
                    <Button Content="←" Style="{StaticResource BtnBack}"
                            HorizontalAlignment="Left" Click="BtnBack_Click"/>
                    <TextBlock Text="Таблица лидеров" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Style="{StaticResource BtnBack}"
                            HorizontalAlignment="Right" Click="BtnBack_Click"/>
                </Grid>

                <!-- Разделитель -->
                <Border Grid.Row="1" Height="1" Background="#1E3820" Margin="20,0"/>

                <!-- Вкладки -->
                <Grid Grid.Row="2" Margin="20,14,20,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnTabGlobal" Grid.Column="0" Content="Общий рейтинг"
                            Style="{StaticResource BtnTabActive}"
                            Click="BtnTabGlobal_Click" Margin="0,0,6,0"/>
                    <Button x:Name="BtnTabFriends" Grid.Column="1" Content="Друзья"
                            Style="{StaticResource BtnTab}"
                            Click="BtnTabFriends_Click" Margin="6,0,0,0"/>
                </Grid>

                <!-- Заголовки таблицы -->
                <Grid Grid.Row="3" Margin="20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Шапка -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="#" Grid.Column="0" Foreground="#557A5A"
                                   FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Игрок" Grid.Column="1" Foreground="#557A5A"
                                   FontSize="12" FontWeight="SemiBold" Margin="8,0"/>
                        <TextBlock Text="Уровень" Grid.Column="2" Foreground="#557A5A"
                                   FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Очки" Grid.Column="3" Foreground="#557A5A"
                                   FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Список -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="360">
                        <ItemsControl x:Name="LeaderList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="row" Background="#162A1A" CornerRadius="10"
                                            Margin="0,0,0,6" Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Место -->
                                            <TextBlock Grid.Column="0" Text="{Binding RankDisplay}"
                                                       FontSize="16" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding RankColor}"/>

                                            <!-- Аватар + имя -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="8,0">
                                                <Border Width="34" Height="34" CornerRadius="17"
                                                        Background="{Binding AvatarColor}">
                                                    <TextBlock Text="{Binding Initials}"
                                                               Foreground="White" FontSize="14"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Nickname}" Foreground="White"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </StackPanel>

                                            <!-- Уровень -->
                                            <TextBlock Grid.Column="2" Text="{Binding Level}"
                                                       Foreground="#7CB87E" FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <!-- Очки -->
                                            <TextBlock Grid.Column="3" Text="{Binding TotalScore}"
                                                       Foreground="White" FontSize="14"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Моё место -->
                <Border Grid.Row="4" Background="#1A6E30" CornerRadius="0,0,16,16"
                        Margin="0" Padding="20,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="Ваше место: " Foreground="#A8E6B0" FontSize="14"/>
                            <TextBlock x:Name="TbMyRank" Text="—" Foreground="White"
                                       FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="TbMyScore" Grid.Column="1"
                                   Foreground="White" FontSize="14" FontWeight="Bold"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- Загрузка -->
        <TextBlock x:Name="TbLoading" Text="Загрузка..." Foreground="#7CB87E"
                   FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</Page>