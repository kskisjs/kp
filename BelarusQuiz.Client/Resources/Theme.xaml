<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ── Цвета ── -->
  <SolidColorBrush x:Key="BgDark"        Color="#0D1F0F"/>
  <SolidColorBrush x:Key="BgCard"        Color="#162B18"/>
  <SolidColorBrush x:Key="BgInput"       Color="#1E3820"/>
  <SolidColorBrush x:Key="AccentGreen"   Color="#2ECC40"/>
  <SolidColorBrush x:Key="AccentGold"    Color="#FFD700"/>
  <SolidColorBrush x:Key="AccentRed"     Color="#E74C3C"/>
  <SolidColorBrush x:Key="TextPrimary"   Color="#FFFFFF"/>
  <SolidColorBrush x:Key="TextSecondary" Color="#7AAB7C"/>
  <SolidColorBrush x:Key="TextMuted"     Color="#4A6B4C"/>
  <SolidColorBrush x:Key="BorderColor"   Color="#2A4A2C"/>

  <Color x:Key="AccentGreenColor" >#2ECC40</Color>
  <Color x:Key="AccentRedColor"   >#E74C3C</Color>

  <!-- ── Шрифты ── -->
  <FontFamily x:Key="FontMain">Segoe UI</FontFamily>

  <!-- ── Стиль кнопки: зелёная ── -->
  <Style x:Key="BtnGreen" TargetType="Button">
    <Setter Property="Background"   Value="#2ECC40"/>
    <Setter Property="Foreground"   Value="#FFFFFF"/>
    <Setter Property="FontSize"     Value="15"/>
    <Setter Property="FontWeight"   Value="Bold"/>
    <Setter Property="Height"       Value="46"/>
    <Setter Property="Cursor"       Value="Hand"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}"
                  CornerRadius="8" Padding="20,0">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="#27AE60"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter Property="Background" Value="#1E8449"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Background" Value="#2A4A2C"/>
              <Setter Property="Foreground" Value="#4A6B4C"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── Стиль кнопки: тёмная ── -->
  <Style x:Key="BtnDark" TargetType="Button">
    <Setter Property="Background"      Value="#1E3820"/>
    <Setter Property="Foreground"      Value="#FFFFFF"/>
    <Setter Property="FontSize"        Value="14"/>
    <Setter Property="Height"          Value="46"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BorderBrush"     Value="#2A4A2C"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8" Padding="20,0">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="#2A4A2C"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── Стиль кнопки ответа ── -->
  <Style x:Key="BtnAnswer" TargetType="Button">
    <Setter Property="Background"      Value="#1E3820"/>
    <Setter Property="Foreground"      Value="#FFFFFF"/>
    <Setter Property="FontSize"        Value="14"/>
    <Setter Property="Height"          Value="54"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BorderBrush"     Value="#2A4A2C"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="10" Padding="16,0">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background"   Value="#2A4A2C"/>
              <Setter Property="BorderBrush"  Value="#2ECC40"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.7"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── TextBox ── -->
  <Style x:Key="InputBox" TargetType="TextBox">
    <Setter Property="Background"      Value="#1E3820"/>
    <Setter Property="Foreground"      Value="#FFFFFF"/>
    <Setter Property="CaretBrush"      Value="#2ECC40"/>
    <Setter Property="FontSize"        Value="15"/>
    <Setter Property="Height"          Value="46"/>
    <Setter Property="Padding"         Value="12,0"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="BorderBrush"     Value="#2A4A2C"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                          VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsFocused" Value="True">
              <Setter Property="BorderBrush" Value="#2ECC40"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── Карточка (панель) ── -->
  <Style x:Key="Card" TargetType="Border">
    <Setter Property="Background"     Value="#162B18"/>
    <Setter Property="CornerRadius"   Value="12"/>
    <Setter Property="Padding"        Value="20"/>
    <Setter Property="BorderBrush"    Value="#2A4A2C"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <!-- ── Полоса прогресса таймера ── -->
  <Style x:Key="TimerBar" TargetType="ProgressBar">
    <Setter Property="Height" Value="6"/>
    <Setter Property="Foreground" Value="#2ECC40"/>
    <Setter Property="Background" Value="#1E3820"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Border Background="{TemplateBinding Background}" CornerRadius="3">
            <Border x:Name="PART_Indicator"
                    Background="{TemplateBinding Foreground}"
                    CornerRadius="3"
                    HorizontalAlignment="Left"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
